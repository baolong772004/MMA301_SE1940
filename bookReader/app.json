{
  "expo": {
    "name": "NovaTales",
    "slug": "novatales",
    "scheme": "novatales",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "sdkVersion": "54.0.0",
    "newArchEnabled": true,
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.novatales.app"
    },
    "android": {
      "package": "com.novatales.app",
      "edgeToEdgeEnabled": true,
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "react-native-nitro-google-signin"
    ]
  }
}
